{
    "name": "@coworkany/desktop",
    "productName": "CoworkAny",
    "description": "Universal AI Assistant - Calendar, Email, Web Automation, Coding & More",
    "version": "0.1.0-beta.2",
    "private": true,
    "type": "module",
    "packageManager": "npm@10.9.4",
    "keywords": [
        "ai-assistant",
        "personal-assistant",
        "productivity",
        "calendar",
        "email",
        "task-management",
        "browser-automation",
        "web-automation",
        "coding-assistant",
        "knowledge-management",
        "self-learning-ai"
    ],
    "scripts": {
        "dev": "vite",
        "dev:tauri-server": "node scripts/start-tauri-dev-server.mjs",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "tauri": "tauri",
        "package:mac:one-click": "bash scripts/build-one-click-installer-zip.sh",
        "test": "bun test tests/phase1-acceptance.test.ts tests/phase2-acceptance.test.ts tests/p2-competitive-acceptance.test.ts",
        "test:ci": "bun test tests/phase1-acceptance.test.ts tests/phase2-acceptance.test.ts",
        "test:e2e": "playwright test",
        "test:e2e:tier1": "playwright test tests/sidecar-spawn-reuse.e2e.test.ts tests/desktop-message-protocol-regression.e2e.test.ts tests/database-failure-recovery-e2e.test.ts tests/timeline-assistant-ui-approval-invoke.e2e.test.ts tests/minimax-market-routing-regression.e2e.test.ts --grep @critical",
        "test:e2e:tier2": "playwright test tests/assistant-ui-markdown-layout-regression.e2e.test.ts && playwright test tests/assistant-ui-thinking-to-response.e2e.spec.ts && playwright test tests/followup-result-ui.e2e.spec.ts && playwright test tests/assistant-ui-visual-regression.e2e.spec.ts && playwright test tests/shell-authorization-ui-regression.e2e.test.ts",
        "test:e2e:tier3": "playwright test tests/onboarding-clean-machine-e2e.test.ts tests/database-failure-recovery-e2e.test.ts tests/interrupted-task-resume-e2e.test.ts tests/window-shell-mac-smoke.test.ts tests/stock-research-desktop-scenarios.e2e.test.ts tests/browser-concurrent-desktop-scenarios.e2e.test.ts",
        "test:e2e:assistant-ui": "playwright test tests/assistant-ui-thinking-to-response.e2e.spec.ts tests/timeline-assistant-ui-approval-invoke.e2e.test.ts tests/assistant-ui-markdown-layout-regression.e2e.test.ts",
        "test:e2e:assistant-ui:visual": "playwright test tests/assistant-ui-visual-regression.e2e.spec.ts",
        "test:e2e:assistant-ui:visual:update": "playwright test tests/assistant-ui-visual-regression.e2e.spec.ts --update-snapshots",
        "test:e2e:smoke": "playwright test tests/sidecar-spawn-reuse.e2e.test.ts tests/sidecar-spawn-reuse-native-mac.test.ts --grep @smoke",
        "test:e2e:regression": "playwright test tests/sidecar-spawn-reuse.e2e.test.ts tests/sidecar-spawn-reuse-native-mac.test.ts tests/desktop-message-protocol-regression.e2e.test.ts tests/minimax-market-routing-regression.e2e.test.ts --grep @regression",
        "test:e2e:market-routing-regression": "playwright test tests/minimax-market-routing-regression.e2e.test.ts --workers=1",
        "test:e2e:smoke:sidecar-reuse": "playwright test tests/sidecar-spawn-reuse-native-mac.test.ts --grep @smoke",
        "test:e2e:x-following": "playwright test tests/x-following-posts-query-e2e.test.ts tests/x-following-posts-suspend-e2e.test.ts",
        "test:native:shell:mac": "node tests/run-native-shell-macos.mjs",
        "test:native:shell:mac:prompt": "node tests/run-native-shell-macos.mjs --prompt-accessibility"
    },
    "dependencies": {
        "@assistant-ui/react": "^0.12.21",
        "@radix-ui/react-dialog": "^1.0.5",
        "@radix-ui/react-toast": "^1.2.15",
        "@radix-ui/react-tooltip": "^1.0.7",
        "@tauri-apps/api": "2.10.1",
        "@tauri-apps/plugin-store": "2.4.2",
        "@tauri-apps/plugin-updater": "2.10.0",
        "clsx": "^2.1.0",
        "i18next": "^25.8.7",
        "react": "^18.3.1",
        "react-diff-viewer-continued": "^3.4.0",
        "react-dom": "^19.2.4",
        "react-error-boundary": "^6.1.0",
        "react-i18next": "^16.5.4",
        "react-markdown": "^10.1.0",
        "remark-breaks": "^4.0.0",
        "remark-gfm": "^4.0.1",
        "zustand": "^4.5.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tailwindcss/postcss": "^4.1.18",
        "@tauri-apps/cli": "2.10.1",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^19.2.3",
        "@types/react-test-renderer": "^18.3.0",
        "@vitejs/plugin-react": "5.1.4",
        "autoprefixer": "^10.4.24",
        "postcss": "^8.5.6",
        "react-test-renderer": "^18.3.1",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.4.5",
        "vite": "6.4.1"
    },
    "overrides": {
        "rollup": "4.59.0"
    },
    "engines": {
        "node": ">=22.22.1 <23"
    }
}
