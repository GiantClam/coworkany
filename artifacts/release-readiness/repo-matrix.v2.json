{
  "version": "1",
  "repos": [
    {
      "repo": "https://github.com/leilei926524-tech/anti-distill",
      "kind": "skill-repo",
      "install": {
        "source": "git",
        "ref": "master"
      },
      "enable": {
        "ids": [
          "anti-distill"
        ]
      },
      "invoke": {
        "mode": "smoke",
        "prompt": "capability smoke"
      },
      "expectedCapabilities": [
        "skills",
        "commands",
        "agents",
        "hooks"
      ]
    },
